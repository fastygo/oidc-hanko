# Copy to .env: cp .env.example .env
# These values are substituted into hanko-config.yaml at runtime where ${VAR} is used.

# PostgreSQL password for user `hanko` (must match database.password in config)
HANKO_DB_PASSWORD=change-me-strong-db-password

# JWT / session signing secret for Hanko (long random string)
HANKO_SESSION_SECRET=change-me-32-byte-random-secret
